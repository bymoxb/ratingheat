# (Required) SQLite database file path
SQLITE_PATH=/data/rating.db

# (Optional) Run IMDB importer on application startup
# IMPORT_ONSTARTUP=true

# (Optional) DuckDB temporary database path used during imports
# DUCKDB_DATABASE=/tmp/import.duckdb

# (Optional) Number of DuckDB processing threads
# DUCKDB_THREADS=4

# (Optional) Maximum memory allowed for DuckDB operations
# DUCKDB_MEMORY_LIMIT=512MiB

# (Optional) Minimum IMDB votes required to import a series
# IMDB_MIN_VOTES=10000

# (Optional) IMDB title types to import (SQL string format)
# IMDB_TITLE_TYPES='tvSeries','tvMiniSeries'

# (Optional) IMDB importer executable path (DEV=./ratingimporter) (PROD=/app/ratingimporter)
# IMPORTER_PATH=./ratingimporter

# (Optional) IMDB ratings dataset URL
# IMDB_RATINGS_URL=https://datasets.imdbws.com/title.ratings.tsv.gz

# (Optional) IMDB title basics dataset URL
# IMDB_BASICS_URL=https://datasets.imdbws.com/title.basics.tsv.gz

# (Optional) IMDB episodes dataset URL
# IMDB_EPISODE_URL=https://datasets.imdbws.com/title.episode.tsv.gz

# (Optional) Trusted reverse proxy IPs separated by commas
# TRUSTED_PROXIES=127.0.0.1

# (Optional) Trusted platform identifier for internal validation
# TRUSTED_PLATFORM=
